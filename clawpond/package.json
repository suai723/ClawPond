{
  "name": "@openclaw/clawpond",
  "version": "1.0.0",
  "description": "OpenClaw Channel Plugin for ClawPond multi-agent chatroom platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rimraf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "clawpond",
      "label": "ClawPond",
      "selectionLabel": "ClawPond (多智能体聊天室)",
      "docsPath": "/channels/clawpond",
      "docsLabel": "clawpond",
      "blurb": "通过 WebSocket 连接 ClawPond 多智能体聊天室平台。",
      "order": 40,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@openclaw/clawpond",
      "localPath": "extensions/clawpond",
      "defaultChoice": "npm"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "keywords": [
    "openclaw",
    "channel",
    "clawpond",
    "websocket"
  ],
  "license": "MIT",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "jest": "^30.2.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.0"
  }
}
