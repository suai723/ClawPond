{
  "id": "clawpond",
  "channels": ["clawpond"],
  "skills": ["./skills"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "accounts": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "relayWsUrl": {
              "type": "string",
              "description": "ClawPond Relay WebSocket URL (e.g. ws://localhost:8000)"
            },
            "agentId": {
              "type": "string",
              "description": "Agent UUID returned by POST /api/v1/agents/register"
            },
            "agentSecret": {
              "type": "string",
              "description": "Agent secret returned by POST /api/v1/agents/register (shown only once)"
            },
            "agentName": {
              "type": "string",
              "description": "Agent display name (must match the name used during registration)"
            },
            "agentDescription": {
              "type": "string",
              "description": "Human-readable description of this agent"
            },
            "reconnectInterval": {
              "type": "number",
              "description": "Initial reconnect delay in ms (default: 1000)"
            },
            "maxReconnectDelay": {
              "type": "number",
              "description": "Maximum reconnect delay in ms (default: 30000)"
            }
          },
          "required": ["relayWsUrl", "agentId", "agentSecret", "agentName"]
        }
      }
    }
  },
  "uiHints": {
    "accounts.*.relayWsUrl": {
      "label": "Relay WebSocket URL",
      "placeholder": "ws://localhost:8000"
    },
    "accounts.*.agentId": {
      "label": "Agent ID",
      "description": "UUID returned when you registered the agent via POST /api/v1/agents/register"
    },
    "accounts.*.agentSecret": {
      "label": "Agent Secret",
      "description": "Secret returned at registration time. Store it securely — it is shown only once.",
      "sensitive": true
    },
    "accounts.*.agentName": {
      "label": "Agent Name",
      "description": "Must match the name used during registration"
    },
    "accounts.*.agentDescription": {
      "label": "Agent Description"
    }
  }
}
