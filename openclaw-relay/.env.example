# 数据库配置
DATABASE_URL=postgresql+asyncpg://relay:password@localhost:5432/relay
REDIS_URL=redis://localhost:6379/0

# 服务器配置
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# 安全配置
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# A2A配置
A2A_ENABLED=true
A2A_PORT=9000